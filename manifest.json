{
  "manifest_version": 3,
  "name": "LigaMagic Prices for Archidekt",
  "version": "1.7.14",
  "description": "Mostra preços da LigaMagic.com.br em decks do Archidekt, por edição e arte exata.",
  "permissions": ["storage", "unlimitedStorage"],
  "host_permissions": [
    "https://www.ligamagic.com.br/*",
    "https://api.scryfall.com/cards/*",
    "https://repositorio.sbrauble.com/*"
  ],
  "background": {
    "service_worker": "src/background/worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://archidekt.com/*"],
      "js": ["src/content/archidekt.js"],
      "css": ["src/content/archidekt.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.ligamagic.com.br/*"],
      "js": ["src/content/ligamagic-import.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/icons/*"],
      "matches": ["https://archidekt.com/*"]
    }
  ],
  "options_page": "popup/popup.html",
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "action": {
    "default_title": "LigaMagic Prices",
    "default_icon": "assets/icons/icon48.png",
    "default_popup": "popup/popup.html"
  }
}
